{
  "version": 2,
  "builds": [
    { "src": "**/*.html", "use": "@vercel/static" },
    { "src": "assets/**/*", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/login", "dest": "/login.html" },
    { "src": "/painel", "dest": "/painel.html" },
    { "src": "/admin", "dest": "/admin.html" },
    { "src": "/certificado", "dest": "/certificado.html" }
  ]
}
